# ─────────────────────────────────────────────────────────────────────────────
# ZELVO MVP — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# Nunca commite .env.local no git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Modo de dados ─────────────────────────────────────────────────────────────
# "local"    → Zustand + localStorage (padrão para desenvolvimento e demo)
# "supabase" → Supabase como banco de dados real (produção)
NEXT_PUBLIC_DATA_MODE=local

# ── Modo de autenticação ───────────────────────────────────────────────────────
# "mock"     → UserSwitcher mockado, sem login real (padrão para demo/dev)
# "supabase" → Supabase Auth real com email + senha, redireciona para /login
NEXT_PUBLIC_AUTH_MODE=mock

# ── Supabase ──────────────────────────────────────────────────────────────────
# Obtenha em: https://supabase.com → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── ATENÇÃO: variáveis de servidor ───────────────────────────────────────────
# A service role key NUNCA deve ser usada no client-side.
# Use somente em Server Actions, Route Handlers ou funções server-side.
# SUPABASE_SERVICE_ROLE_KEY=     ← adicione apenas em .env.local (nunca no .env.example publico)
