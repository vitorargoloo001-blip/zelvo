# ─────────────────────────────────────────────────────────────────────────────
# ZELVO MVP — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# Nunca commite .env.local no git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Modo de dados ─────────────────────────────────────────────────────────────
# "local" → Zustand + localStorage (padrão para desenvolvimento e demo)
# "cloud" → Postgres (Vercel/Neon) via Prisma como banco de dados real (produção)
NEXT_PUBLIC_DATA_MODE=local

# ── Modo de autenticação ───────────────────────────────────────────────────────
# "mock"  → UserSwitcher mockado, sem login real (padrão para demo/dev)
# "cloud" → Auth.js (NextAuth) real com email + senha, redireciona para /login
NEXT_PUBLIC_AUTH_MODE=mock

# ── Vercel Postgres (Neon) ────────────────────────────────────────────────────
# Provisionado em: Vercel dashboard → Storage → Postgres (injeta estas vars automaticamente)
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# ── Auth.js ───────────────────────────────────────────────────────────────────
# Gere com: npx auth secret  (ou: openssl rand -base64 32)
AUTH_SECRET=

# ── Resend (e-mails transacionais) ──────────────────────────────────────────
# Opcional — sem a key, o sistema loga o link de recuperação em vez de enviar email
# Usado também para notificações de lead atribuído e Lead Premium.
RESEND_API_KEY=

# Endereço "De:" para e-mails de notificação do sistema.
# Padrão usado se não configurado: Zelvo CRM <noreply@zelvo.com.br>
# Requer domínio verificado no Resend.
RESEND_FROM_EMAIL=

# ── Intake de leads externos ─────────────────────────────────────────────────
# Token enviado pela landing page no header x-zelvo-intake-secret.
# Gere com: openssl rand -hex 32
# IMPORTANTE: nunca use prefixo NEXT_PUBLIC_ — deve ficar APENAS no servidor.
LEAD_INTAKE_SECRET=

# Origens HTTP permitidas para o endpoint de intake (CSV, sem espaços após vírgula).
# Exemplo: https://landingcliente.com.br,https://zelvo-form.vercel.app
# Deixe vazio para aceitar qualquer origem (não recomendado em produção).
LEAD_INTAKE_ALLOWED_ORIGINS=
